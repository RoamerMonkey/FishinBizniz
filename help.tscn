theme_override_font_sizes/font_size = 60
text = "Play as the Fisher and/or the Hunter in a quest to earn the most points in a 1-minute round!

You earn points from capturing the swimming fish. The Fisher hooks the fish out of the water. The Hunter shoots the fish dead.

Compete Mode ranks between the Fisher and Hunter's scores to determine a winner. Collaborate Mode combines the Fisher and Hunter's scores for a total score."
vertical_alignment = 1
autowrap_mode = 2

